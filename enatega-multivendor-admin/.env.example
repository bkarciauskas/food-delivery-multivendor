# Hosted demo API (default). For a licensed local API use http://localhost:8001/ and ws://localhost:8001/
NEXT_PUBLIC_SERVER_URL="https://aws-server-v2.enatega.com/"
NEXT_PUBLIC_WS_SERVER_URL="wss://aws-server-v2.enatega.com/"

# Optional local stub (scripts/demo-graphql-stub.mjs) via same-origin rewrite:
# DEMO_GRAPHQL_PROXY=1
# DEMO_GRAPHQL_PROXY_TARGET=http://127.0.0.1:8001
# NEXT_PUBLIC_SERVER_URL="http://localhost:3001/"
# NEXT_PUBLIC_WS_SERVER_URL="ws://localhost:3001/"

# Required for Google Maps in the browser (code reads NEXT_PUBLIC_GOOGLE_MAPS_API_KEY)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — prefills on the admin login form only
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_PASSWORD=

# Optional — client-side decryption helper
NEXT_PUBLIC_ENCRYPTION_KEY=
